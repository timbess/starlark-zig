# Iterate over range
print("range iteration:")
for i in range(3):
    print(i)

# Iterate over list
print("list iteration:")
for item in [10, 20, 30]:
    if item != 20:
        print(item)

# Nested loops
print("nested loops:")
for i in range(2):
    for j in range(3):
        print(i, j)

print("Done!")
